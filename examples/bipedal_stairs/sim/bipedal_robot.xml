<?xml version="1.0" ?>
<mujoco model="bipedal_robot">
    <compiler angle="radian" coordinate="local" inertiafromgeom="true"/>
    <option integrator="RK4" timestep="0.002"/>
    
    <default>
        <joint type="hinge" damping="0.01" frictionloss="0.0"/>
        <geom contype="1" conaffinity="1" friction="0.8 0.1 0.1"/>
    </default>
    
    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"/>
        <texture name="grid" type="2d" builtin="checker" rgb1="0.1 0.1 0.1" rgb2="0.9 0.9 0.9" width="300" height="300"/>
        <material name="grid" texture="grid" texrepeat="1 1" specular="0.0"/>
    </asset>
    
    <worldbody>
        <!-- Ground reference -->
        <geom name="floor" type="plane" size="10 10 0.1" material="grid"/>
        
        <!-- Torso (fixed in Y, Z rotations) -->
        <body name="torso" pos="0 0 1.0">
            <inertial mass="10" pos="0 0 0" diaginv="0.1 0.1 0.1"/>
            <geom name="torso_geom" type="capsule" fromto="0 0 -0.2 0 0 0.2" radius="0.15"/>
            
            <!-- Hip joint Y (roll) - FIXED -->
            <joint name="torso_roll" type="hinge" axis="0 1 0" range="-0.2 0.2" stiffness="0" damping="0.01" limited="true"/>
            
            <!-- Hip joint Z (yaw) - FIXED -->
            <joint name="torso_yaw" type="hinge" axis="0 0 1" range="-0.1 0.1" stiffness="0" damping="0.01" limited="true"/>
            
            <!-- Left leg -->
            <body name="left_hip" pos="0 0.1 0">
                <inertial mass="2" pos="0 0 -0.3" diaginv="0.01 0.01 0.01"/>
                <geom name="left_hip_geom" type="capsule" fromto="0 0 0 0 0 -0.6" radius="0.08"/>
                
                <!-- Left hip pitch (X) - CONTROLLED -->
                <joint name="left_hip_pitch" type="hinge" axis="1 0 0" range="-1.57 1.57" damping="0.05"/>
                
                <!-- Left knee -->
                <body name="left_knee" pos="0 0 -0.6">
                    <inertial mass="1.5" pos="0 0 -0.3" diaginv="0.01 0.01 0.01"/>
                    <geom name="left_knee_geom" type="capsule" fromto="0 0 0 0 0 -0.6" radius="0.07"/>
                    
                    <!-- Left knee pitch (X) - CONTROLLED -->
                    <joint name="left_knee_pitch" type="hinge" axis="1 0 0" range="-1.57 1.57" damping="0.05"/>
                    
                    <!-- Left ankle -->
                    <body name="left_ankle" pos="0 0 -0.6">
                        <inertial mass="1" pos="0 0 -0.1" diaginv="0.01 0.01 0.01"/>
                        <geom name="left_ankle_geom" type="capsule" fromto="0 0 0 0 0 -0.15" radius="0.06"/>
                        <geom name="left_foot" type="box" pos="0 0 -0.15" size="0.08 0.06 0.04"/>
                        
                        <!-- Left ankle pitch (X) - CONTROLLED -->
                        <joint name="left_ankle_pitch" type="hinge" axis="1 0 0" range="-0.785 0.785" damping="0.05"/>
                    </body>
                </body>
            </body>
            
            <!-- Right leg -->
            <body name="right_hip" pos="0 -0.1 0">
                <inertial mass="2" pos="0 0 -0.3" diaginv="0.01 0.01 0.01"/>
                <geom name="right_hip_geom" type="capsule" fromto="0 0 0 0 0 -0.6" radius="0.08"/>
                
                <!-- Right hip pitch (X) - CONTROLLED -->
                <joint name="right_hip_pitch" type="hinge" axis="1 0 0" range="-1.57 1.57" damping="0.05"/>
                
                <!-- Right knee -->
                <body name="right_knee" pos="0 0 -0.6">
                    <inertial mass="1.5" pos="0 0 -0.3" diaginv="0.01 0.01 0.01"/>
                    <geom name="right_knee_geom" type="capsule" fromto="0 0 0 0 0 -0.6" radius="0.07"/>
                    
                    <!-- Right knee pitch (X) - CONTROLLED -->
                    <joint name="right_knee_pitch" type="hinge" axis="1 0 0" range="-1.57 1.57" damping="0.05"/>
                    
                    <!-- Right ankle -->
                    <body name="right_ankle" pos="0 0 -0.6">
                        <inertial mass="1" pos="0 0 -0.1" diaginv="0.01 0.01 0.01"/>
                        <geom name="right_ankle_geom" type="capsule" fromto="0 0 0 0 0 -0.15" radius="0.06"/>
                        <geom name="right_foot" type="box" pos="0 0 -0.15" size="0.08 0.06 0.04"/>
                        
                        <!-- Right ankle pitch (X) - CONTROLLED -->
                        <joint name="right_ankle_pitch" type="hinge" axis="1 0 0" range="-0.785 0.785" damping="0.05"/>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>
    
    <actuator>
        <!-- Left leg actuators -->
        <motor name="left_hip_motor" joint="left_hip_pitch" ctrlrange="-20 20" ctrllimited="true"/>
        <motor name="left_knee_motor" joint="left_knee_pitch" ctrlrange="-15 15" ctrllimited="true"/>
        <motor name="left_ankle_motor" joint="left_ankle_pitch" ctrlrange="-10 10" ctrllimited="true"/>
        
        <!-- Right leg actuators -->
        <motor name="right_hip_motor" joint="right_hip_pitch" ctrlrange="-20 20" ctrllimited="true"/>
        <motor name="right_knee_motor" joint="right_knee_pitch" ctrlrange="-15 15" ctrllimited="true"/>
        <motor name="right_ankle_motor" joint="right_ankle_pitch" ctrlrange="-10 10" ctrllimited="true"/>
    </actuator>
    
    <sensor>
        <!-- Joint angle sensors -->
        <jointpos name="left_hip_pos" joint="left_hip_pitch"/>
        <jointpos name="left_knee_pos" joint="left_knee_pitch"/>
        <jointpos name="left_ankle_pos" joint="left_ankle_pitch"/>
        <jointpos name="right_hip_pos" joint="right_hip_pitch"/>
        <jointpos name="right_knee_pos" joint="right_knee_pitch"/>
        <jointpos name="right_ankle_pos" joint="right_ankle_pitch"/>
        
        <!-- Joint velocity sensors -->
        <jointvel name="left_hip_vel" joint="left_hip_pitch"/>
        <jointvel name="left_knee_vel" joint="left_knee_pitch"/>
        <jointvel name="left_ankle_vel" joint="left_ankle_pitch"/>
        <jointvel name="right_hip_vel" joint="right_hip_pitch"/>
        <jointvel name="right_knee_vel" joint="right_knee_pitch"/>
        <jointvel name="right_ankle_vel" joint="right_ankle_pitch"/>
        
        <!-- Position sensors -->
        <framepos name="torso_pos" objtype="body" objname="torso"/>
        <framepos name="left_foot_pos" objtype="body" objname="left_ankle"/>
        <framepos name="right_foot_pos" objtype="body" objname="right_ankle"/>
    </sensor>
</mujoco>
