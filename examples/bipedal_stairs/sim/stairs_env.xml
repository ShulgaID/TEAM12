        <!-- Step 5 -->
        <geom name="stair_5" type="box" pos="2.0 0 1.35" size="0.4 0.15 0.15" material="stair"/>
        
        <!-- Step 6 -->
        <geom name="stair_6" type="box" pos="2.4 0 1.65" size="0.4 0.15 0.15" material="stair"/>
        
